generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model FamilyTree {
  id            String         @id @default(cuid())
  title         String
  description   String?
  people        Person[]
  relationships Relationship[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Person {
  id             String                 @id @default(cuid())
  familyTreeId   String
  familyTree     FamilyTree             @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String?
  displayName    String?
  gender         String?
  primaryRelation String?
  dateOfBirth    DateTime?
  photoUrl       String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  country        String?
  notes          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  relationshipsA Relationship[]         @relation("relationshipFrom")
  relationshipsB Relationship[]         @relation("relationshipTo")
}

model Relationship {
  id           String     @id @default(cuid())
  familyTreeId String
  fromId       String
  toId         String
  type         String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  familyTree   FamilyTree @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)
  from         Person     @relation("relationshipFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to           Person     @relation("relationshipTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([familyTreeId, type])
  @@index([fromId, type])
  @@index([toId, type])
}
